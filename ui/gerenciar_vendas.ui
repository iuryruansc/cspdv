     <property name="styleSheet">
      <string notr="true">
       QFrame#frameNavBar { background-color: #1a5fa0; }
       QPushButton {
        background-color: transparent;
        color: #c8dff4;
        font-size: 12px;
        font-weight: bold;
        border: none;
        border-bottom: 3px solid transparent;
        min-height: 44px;
        padding: 6px 18px;
