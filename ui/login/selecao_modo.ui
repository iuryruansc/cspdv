 color: white;
 border: 1px solid #2b5e87;
 border-radius: 10px;
 padding: 10px 14px;
 font-size: 12px;
 font-weight: bold;
 text-align: center;
}
QPushButton[moduleCard=&quot;true&quot;]:hover {
 background-color: #1d466c;
 border-color: #3d78a8;
}
QPushButton[moduleCard=&quot;true&quot;]:pressed {
 background-color: #10314e;
}
QPushButton#btnSairSessao {
