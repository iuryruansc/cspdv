           <item>
            <widget class="QTableWidget" name="tablePreVendasAberto">
             <property name="styleSheet">
              <string notr="true">
               QTableWidget {
                background-color: #ffffff;
                alternate-background-color: #f4f9fd;
                border: 1px solid #a8c4d8;
                border-top: none;
                border-bottom-left-radius: 4px;
                border-bottom-right-radius: 4px;
                font-size: 12px;
                gridline-color: #dce8f0;
                outline: 0;
               }
               QTableWidget::item {
                padding: 2px 6px;
                color: #111111;
               }
               QTableWidget::item:selected {
                background-color: #3585c8;
                color: #ffffff;
               }
               QTableWidget::item:hover:!selected {
                background-color: #ddeef8;
               }
               QHeaderView::section:horizontal {
                background-color: #ffffff;
                color: #111111;
                font-size: 12px;
                font-weight: bold;
                padding: 4px 6px;
                border: none;
                border-right: 1px solid #dce8f0;
                border-bottom: 2px solid #3585c8;
               }
               QHeaderView::section:horizontal:last {
                border-right: none;
               }
               QHeaderView::section:vertical {
                background-color: #ffffff;
                color: #ffffff;
                border: none;
                border-bottom: 1px solid #dce8f0;
                border-right: 1px solid #dce8f0;
                width: 16px;
                padding: 0;
               }
               QHeaderView::section:vertical:checked {
                background-color: #3585c8;
               }
               QTableCornerButton::section {
                background-color: #ffffff;
                border: none;
                border-bottom: 2px solid #3585c8;
                border-right: 1px solid #dce8f0;
               }
               QScrollBar:vertical {
                background: #f0f4f8;
                width: 10px;
                margin: 0;
               }
               QScrollBar::handle:vertical {
                background: #a8c4d8;
                border-radius: 4px;
                min-height: 20px;
               }
               QScrollBar::handle:vertical:hover {
                background: #3585c8;
               }
               QScrollBar::add-line:vertical,
               QScrollBar::sub-line:vertical {
                height: 0px;
               }
              </string>
             </property>
             <property name="columnCount"><number>2</number></property>
             <property name="rowCount"><number>0</number></property>
             <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
