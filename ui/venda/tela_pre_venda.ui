         </widget>
        </item>
        <item>
         <widget class="QTableWidget" name="tableCupomFiscal">
          <property name="styleSheet">
           <string notr="true">
             /* ── Corpo da tabela ── */
             QTableWidget {
              background-color: #ffffff;
              alternate-background-color: #f4f9fd;
              border: 1px solid #a8c4d8;
              border-top: none;
              font-size: 11px;
              font-family: Arial;
              gridline-color: #dce8f0;
              outline: 0;
             }

             /* ── Célula normal ── */
             QTableWidget::item {
              padding: 1px 5px;
              color: #111111;
              border: none;
             }

             /* ── Linha selecionada (simula o azul da imagem) ── */
             QTableWidget::item:selected {
              background-color: #3585c8;
              color: #ffffff;
             }

             /* ── Hover (linha sob o cursor, sem seleção) ── */
             QTableWidget::item:hover:!selected {
              background-color: #ddeef8;
             }

             /* ── Cabeçalho de colunas ──
                  Fundo branco, texto em negrito, separado dos dados
                  por uma linha azul sólida de 2px (igual à imagem) */
             QHeaderView {
              background-color: #ffffff;
             }
             QHeaderView::section:horizontal {
              background-color: #ffffff;
              color: #111111;
              font-size: 11px;
              font-weight: bold;
              font-family: Arial;
              padding: 3px 5px;
              border: none;
              border-right: 1px solid #dce8f0;
              border-bottom: 2px solid #3585c8;
             }
             QHeaderView::section:horizontal:last {
              border-right: none;
             }
             /* Impede que o cabeçalho mude de aparência ao selecionar coluna */
             QHeaderView::section:horizontal:checked {
              background-color: #ffffff;
              color: #111111;
             }

             /* ── Cabeçalho vertical (coluna do indicador de linha) ──
                  Exibe ► na linha corrente, igual ao ponteiro da imagem */
             QHeaderView::section:vertical {
              background-color: #ffffff;
              color: #ffffff;           /* oculta os números de linha */
              border: none;
              border-bottom: 1px solid #dce8f0;
              border-right: 1px solid #dce8f0;
              width: 16px;
              padding: 0;
             }
             /* Linha corrente: fundo azul + símbolo ► via cor */
             QHeaderView::section:vertical:checked {
              background-color: #3585c8;
              color: #3585c8;           /* ► é desenhado pelo Qt em cima */
             }

             /* ── Canto superior-esquerdo (intersecção dos dois headers) ── */
             QTableCornerButton::section {
              background-color: #ffffff;
              border: none;
              border-bottom: 2px solid #3585c8;
              border-right: 1px solid #dce8f0;
             }

             /* ── Scroll bars discretas ── */
             QScrollBar:vertical {
              background: #f0f4f8;
              width: 10px;
              margin: 0;
             }
             QScrollBar::handle:vertical {
              background: #a8c4d8;
              border-radius: 4px;
              min-height: 20px;
             }
             QScrollBar::handle:vertical:hover {
              background: #3585c8;
             }
             QScrollBar::add-line:vertical,
             QScrollBar::sub-line:vertical {
              height: 0px;
             }
            </string>
          </property>
          <property name="editTriggers">
           <set>QAbstractItemView::NoEditTriggers</set>
          </property>
          <property name="alternatingRowColors">
           <bool>true</bool>
          </property>
          <property name="selectionMode">
           <enum>QAbstractItemView::SingleSelection</enum>
          </property>
          <property name="selectionBehavior">
           <enum>QAbstractItemView::SelectRows</enum>
          </property>
          <property name="showGrid">
           <bool>true</bool>
          </property>
          <property name="gridStyle">
           <enum>Qt::SolidLine</enum>
          </property>
          <property name="sortingEnabled">
           <bool>false</bool>
          </property>
          <property name="wordWrap">
           <bool>false</bool>
          </property>
          <property name="rowCount">
           <number>0</number>
