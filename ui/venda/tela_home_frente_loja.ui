         <item>
          <widget class="QTableWidget" name="tableUltimasVendas">
           <property name="styleSheet">
            <string notr="true">
             QTableWidget{background-color:#081828;alternate-background-color:#0a1e30;border:none;border-bottom-left-radius:8px;border-bottom-right-radius:8px;font-size:12px;gridline-color:#1a3a5a;outline:0;color:#a0c8e8;}
             QTableWidget::item{padding:5px 10px;}
             QTableWidget::item:selected{background-color:#1a4a7a;color:white;}
             QTableWidget::item:hover:!selected{background-color:#0f2840;}
             QHeaderView::section:horizontal{background-color:#0a1828;color:#2a5a7a;font-size:11px;font-weight:bold;padding:5px 10px;border:none;border-right:1px solid #1a3a5a;border-bottom:1px solid #1a3a5a;}
             QHeaderView::section:horizontal:last{border-right:none;}
             QHeaderView::section:horizontal:checked{background-color:#0a1828;color:#2a5a7a;}
             QHeaderView::section:vertical{background-color:#0a1828;color:#0a1828;border:none;border-bottom:1px solid #1a3a5a;border-right:1px solid #1a3a5a;width:14px;}
             QHeaderView::section:vertical:checked{background-color:#1a4a7a;color:#1a4a7a;}
             QTableCornerButton::section{background-color:#0a1828;border:none;border-bottom:1px solid #1a3a5a;border-right:1px solid #1a3a5a;}
             QScrollBar:vertical{background:#081828;width:8px;margin:0;}
             QScrollBar::handle:vertical{background:#1a3a5a;border-radius:3px;min-height:20px;}
             QScrollBar::handle:vertical:hover{background:#3585c8;}
             QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0px;}
            </string>
           </property>
           <property name="columnCount"><number>5</number></property>
