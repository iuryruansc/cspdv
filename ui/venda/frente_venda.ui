             QTableWidget::item:hover:!selected{background-color:#ddeef8;}
             QHeaderView::section:horizontal{background-color:#ffffff;color:#111111;font-size:12px;font-weight:bold;padding:4px 6px;border:none;border-right:1px solid #dce8f0;border-bottom:2px solid #3585c8;}
             QHeaderView::section:horizontal:last{border-right:none;}
             QHeaderView::section:horizontal:checked{background-color:#ffffff;color:#111111;}
             QHeaderView::section:vertical{background-color:#ffffff;color:#ffffff;border:none;border-bottom:1px solid #dce8f0;border-right:1px solid #dce8f0;width:16px;}
             QHeaderView::section:vertical:checked{background-color:#3585c8;color:#3585c8;}
             QTableCornerButton::section{background-color:#ffffff;border:none;border-bottom:2px solid #3585c8;border-right:1px solid #dce8f0;}
             QScrollBar:vertical{background:#f0f4f8;width:10px;margin:0;}
             QScrollBar::handle:vertical{background:#a8c4d8;border-radius:4px;min-height:20px;}
             QScrollBar::handle:vertical:hover{background:#3585c8;}
             QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0px;}
