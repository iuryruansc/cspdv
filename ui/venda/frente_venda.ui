          <property name="styleSheet">
           <string notr="true">
             QTableWidget{background-color:#ffffff;alternate-background-color:#f2f8fc;border:1px solid #a8c4d8;border-top:none;border-bottom-left-radius:4px;border-bottom-right-radius:4px;font-size:12px;gridline-color:#dce8f0;outline:0;}
