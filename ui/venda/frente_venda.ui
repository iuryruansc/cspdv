          <property name="styleSheet">
           <string notr="true">
             QTableWidget{background-color:#ffffff;alternate-background-color:#f5f9fc;border:1px solid #214b6a;border-top:none;border-bottom-left-radius:10px;border-bottom-right-radius:10px;font-size:12px;gridline-color:#d8e4ee;outline:0;color:#111111;}
