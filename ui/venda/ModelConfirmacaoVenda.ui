        <property name="minimumSize"><size><width>22</width><height>22</height></size></property>
        <property name="maximumSize"><size><width>22</width><height>22</height></size></property>
        <property name="styleSheet">
         <string notr="true">
          QPushButton{background-color:#cc2222;border:none;border-radius:11px;color:white;font-size:11px;font-weight:bold;}
