          <layout class="QVBoxLayout"><property name="spacing"><number>2</number></property>
           <item><widget class="QLabel" name="lblNumVendaLabel"><property name="text"><string>Venda n&#186;</string></property><property name="styleSheet"><string notr="true">font-size:10px;color:#5580a0;</string></property></widget></item>
           <item><widget class="QLabel" name="lblNumVendaValor"><property name="text"><string>---</string></property><property name="styleSheet"><string notr="true">font-size:18px;font-weight:bold;color:#1a5fa0;</string></property></widget></item>
          </layout>
         </item>

         <!-- Separador -->
         <item>
          <widget class="QFrame" name="frameSep1">
