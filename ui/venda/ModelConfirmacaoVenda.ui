   <!-- CONTEÚDO -->
   <item>
    <widget class="QFrame" name="frameConteudo">
     <property name="styleSheet">
      <string notr="true">
       QFrame#frameConteudo {
        background-color: #e8f2fa;
        border: 2px solid #2a70b8;
        border-top: none;
        border-bottom-left-radius: 4px;
        border-bottom-right-radius: 4px;
