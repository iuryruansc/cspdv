         <!-- Data/hora -->
         <item>
          <layout class="QVBoxLayout"><property name="spacing"><number>2</number></property>
           <item><widget class="QLabel" name="lblDataHoraLabel"><property name="text"><string>Data / Hora</string></property><property name="styleSheet"><string notr="true">font-size:10px;color:#5580a0;</string></property></widget></item>
           <item><widget class="QLabel" name="lblDataHoraValor"><property name="text"><string>--/--/---- --:--</string></property><property name="styleSheet"><string notr="true">font-size:12px;color:#1a3a5c;</string></property></widget></item>
