        <item>
         <widget class="QTableWidget" name="tableUltimasVendas">
          <property name="styleSheet">
           <string notr="true">
             QTableWidget{background-color:#f4f8fc;alternate-background-color:#f2f8fc;border:none;border-bottom-left-radius:8px;border-bottom-right-radius:8px;font-size:12px;gridline-color:#dce8f0;outline:0;color:#1a3a5c;}
             QTableWidget::item{padding:5px 10px;}
             QTableWidget::item:selected{background-color:#3585c8;color:#ffffff;}
             QTableWidget::item:hover:!selected{background-color:#ffffff;}
             QHeaderView::section:horizontal{background-color:#f0f6fc;color:#5580a0;font-size:11px;font-weight:bold;padding:5px 10px;border:none;border-right:1px solid #a8c4d8;border-bottom:1px solid #1a3a5a;}
             QHeaderView::section:horizontal:last{border-right:none;}
             QHeaderView::section:horizontal:checked{background-color:#f0f6fc;color:#5580a0;}
             QHeaderView::section:vertical{background-color:#f0f6fc;color:#0a1828;border:none;border-bottom:1px solid #1a3a5a;border-right:1px solid #a8c4d8;width:14px;}
             QHeaderView::section:vertical:checked{background-color:#3585c8;color:#3585c8;}
             QTableCornerButton::section{background-color:#f0f6fc;border:none;border-bottom:1px solid #1a3a5a;border-right:1px solid #a8c4d8;}
             QScrollBar:vertical{background:#f0f4f8;width:8px;margin:0;}
             QScrollBar::handle:vertical{background:#a8c4d8;border-radius:3px;min-height:20px;}
             QScrollBar::handle:vertical:hover{background:#3585c8;}
             QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0px;}
            </string>
          </property>
          <property name="editTriggers">
