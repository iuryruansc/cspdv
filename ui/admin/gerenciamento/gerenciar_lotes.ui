               QTableWidget{background-color:#ffffff;alternate-background-color:#f2f8fc;border:none;border-bottom-left-radius:6px;border-bottom-right-radius:6px;font-size:12px;gridline-color:#dce8f0;outline:0;}
               QTableWidget::item{padding:4px 8px;color:#111111;}
               QTableWidget::item:selected{background-color:#3585c8;color:#ffffff;}
               QTableWidget::item:hover:!selected{background-color:#ddeef8;}
               QHeaderView::section:horizontal{background-color:#f0f6fc;color:#1a3a5c;font-size:12px;font-weight:bold;padding:5px 8px;border:none;border-right:1px solid #dce8f0;border-bottom:2px solid #3585c8;}
               QHeaderView::section:horizontal:last{border-right:none;}
               QHeaderView::section:horizontal:checked{background-color:#f0f6fc;color:#1a3a5c;}
               QHeaderView::section:vertical{background-color:#ffffff;color:#ffffff;border:none;border-bottom:1px solid #dce8f0;border-right:1px solid #dce8f0;width:16px;}
               QHeaderView::section:vertical:checked{background-color:#3585c8;color:#3585c8;}
               QTableCornerButton::section{background-color:#f0f6fc;border:none;border-bottom:2px solid #3585c8;border-right:1px solid #dce8f0;}
               QScrollBar:vertical{background:#f0f4f8;width:10px;margin:0;}
               QScrollBar::handle:vertical{background:#a8c4d8;border-radius:4px;min-height:20px;}
               QScrollBar::handle:vertical:hover{background:#3585c8;}
               QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0px;}
               QScrollBar:horizontal{background:#f0f4f8;height:10px;margin:0;}
               QScrollBar::handle:horizontal{background:#a8c4d8;border-radius:4px;min-width:20px;}
               QScrollBar::handle:horizontal:hover{background:#3585c8;}
               QScrollBar::add-line:horizontal,QScrollBar::sub-line:horizontal{width:0px;}
              </string>
            </property>
