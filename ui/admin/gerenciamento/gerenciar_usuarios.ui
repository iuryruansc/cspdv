     <property name="styleSheet">
      <string notr="true">
       QFrame#frameNavBar { background-color: #1a5fa0; }
       QPushButton {
        background-color: transparent;
        color: #c8dff4;
        font-size: 12px;
        font-weight: bold;
        border: none;
        border-bottom: 3px solid transparent;
        min-height: 44px;
        padding: 6px 18px;
       }
       QPushButton:hover {
        color: white;
        background-color: rgba(255,255,255,15);
        border-bottom: 3px solid rgba(255,255,255,60);
       }
       QPushButton:checked {
        color: white;
        background-color: rgba(255,255,255,20);
        border-bottom: 3px solid #ffe080;
       }
       /* Sub-itens de catálogo (marcas/fornec/categ) — fonte menor */
       QPushButton[navSub="true"] {
        font-size: 11px;
        padding: 4px 12px;
        color: #a8d4f0;
       }
       QPushButton[navSub="true"]:hover  { color: white; }
       QPushButton[navSub="true"]:checked { color: white; }
      </string>
