           <item>
            <widget class="QTableWidget" name="tableUltimasVendas">
             <property name="styleSheet">
              <string notr="true">
                QTableWidget {
                 background-color: #ffffff;
                 border: none;
                 font-size: 12px;
                 gridline-color: #dce8f0;
                 outline: 0;
                }
                QTableWidget::item { padding: 3px 6px; color: #111111; }
                QTableWidget::item:selected { background-color: #3585c8; color: white; }
                QTableWidget::item:alternate { background-color: #f2f8fc; }
                QHeaderView::section:horizontal {
                 background-color: #f0f6fc;
                 color: #1a3a5c;
                 font-size: 11px;
                 font-weight: bold;
                 padding: 4px 6px;
                 border: none;
                 border-right: 1px solid #dce8f0;
                 border-bottom: 2px solid #3585c8;
                }
                QHeaderView::section:horizontal:last { border-right: none; }
                QHeaderView::section:horizontal:checked { background-color: #f0f6fc; }
                QHeaderView::section:vertical {
                 background-color: #ffffff; color: #ffffff;
                 border: none; border-bottom: 1px solid #dce8f0;
                 border-right: 1px solid #dce8f0; width: 16px;
                }
                QHeaderView::section:vertical:checked { background-color: #3585c8; color: #3585c8; }
                QTableCornerButton::section {
                 background-color: #f0f6fc; border: none;
                 border-bottom: 2px solid #3585c8; border-right: 1px solid #dce8f0;
                }
                QScrollBar:vertical { background: #f0f4f8; width: 10px; margin: 0; }
